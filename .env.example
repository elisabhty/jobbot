# === TWILIO (WhatsApp) ===
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# === ANTHROPIC (Claude AI) ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# === STRIPE (Paiements) ===
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# === ADZUNA (Offres d'emploi — optionnel) ===
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key

# === FRANCE TRAVAIL (optionnel) ===
# Option A — OAuth2 (recommandé, token auto-renouvelé)
FRANCE_TRAVAIL_CLIENT_ID=your_client_id
FRANCE_TRAVAIL_CLIENT_SECRET=your_client_secret
# Option B — Token statique legacy (expire toutes les 24h, déconseillé)
FRANCE_TRAVAIL_TOKEN=your_static_token

# === DASHBOARD ===
DASHBOARD_SECRET=une_chaine_aleatoire_longue

# === EMAIL (pour candidatures automatiques) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# === APP ===
BASE_URL=https://your-app.railway.app
PORT=3000

# === ABONNEMENT ===
# Prix affiché dans les messages WhatsApp (adapter selon ton produit Stripe)
SUBSCRIPTION_PRICE=4,99
# Période affichée : "semaine" ou "mois"
SUBSCRIPTION_PERIOD=semaine
# Durée d'essai gratuit en jours (0 = pas d'essai)
TRIAL_DAYS=7
